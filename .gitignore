# Python
__pycache__/
*.py[cod]
*$py.class

# Build / packaging
build/
dist/
*.egg-info/

# Testing
.pytest_cache/
.coverage
htmlcov/

# IDE
.vscode/
.idea/

# Ignore all images by default
*.png
*.jpg
*.jpeg

# ✅ Allow ONLY demo images
!cad.png
!real.png

# (Optional) allow README images folder
!README_images/
!README_images/*.png

# Ignore debug/test images
debug_*.png
test_*.png
*_overlay.png
*_aligned.png
*_comparison.png
*_result.png

# Ignore temp files
*.tmp
*.temp